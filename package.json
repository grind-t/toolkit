{
  "name": "@grind-t/toolkit",
  "version": "2.1.0",
  "author": "grind-t",
  "description": "Natural problem solver's toolkit",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./nullish": {
      "types": "./dist/nullish.d.ts",
      "import": "./dist/nullish.js",
      "require": "./dist/nullish.cjs"
    },
    "./string": {
      "types": "./dist/string.d.ts",
      "import": "./dist/string.js",
      "require": "./dist/string.cjs"
    },
    "./array": {
      "types": "./dist/array.d.ts",
      "import": "./dist/array.js",
      "require": "./dist/array.cjs"
    },
    "./date": {
      "types": "./dist/date.d.ts",
      "import": "./dist/date.js",
      "require": "./dist/date.cjs"
    },
    "./fn": {
      "types": "./dist/fn.d.ts",
      "import": "./dist/fn.js",
      "require": "./dist/fn.cjs"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "npx @biomejs/biome check --write",
    "test:unit": "node --experimental-transform-types --experimental-test-module-mocks --test \"src/**/*.unit.test.ts\"",
    "test:e2e": "node --experimental-transform-types --experimental-test-module-mocks --test \"src/**/*.e2e.test.ts\"",
    "test": "node --experimental-transform-types --experimental-test-module-mocks --test \"src/**/*.test.ts\"",
    "check": "npm run typecheck && npm run lint && npm run test",
    "build": "tsup"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grind-t/toolkit.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/grind-t/toolkit/issues"
  },
  "homepage": "https://github.com/grind-t/toolkit#readme",
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@microsoft/api-extractor": "latest",
    "@swc/core": "latest",
    "@types/node": "latest",
    "tsup": "latest",
    "typescript": "latest"
  }
}
